    "DefaultConnection": "Host=localhost;Port=5432;Database=telegram_post_aggregator;Username=postgres;Password=postgres"
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=telegram_post_aggregator;Username=postgres;Password=postgres"
