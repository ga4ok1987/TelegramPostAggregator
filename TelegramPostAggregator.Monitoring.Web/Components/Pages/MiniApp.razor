@page "/mini-app"
@layout Layout.MiniAppLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject ViewModels.MiniAppViewModel ViewModel

<PageTitle>Channels Monitor Mini App</PageTitle>

<div class="miniapp-screen">
    <header class="miniapp-topbar">
        <button class="icon-button" type="button" @onclick="OpenDrawerAsync" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="miniapp-title-wrap">
            <h1>@CurrentTitle</h1>
            <p>@CurrentSubtitle</p>
        </div>

        @if (ActiveTab == MiniAppTab.Channels)
        {
            <button class="icon-button accent" type="button" @onclick="ShowAddChannelHintAsync" aria-label="Add channel">+</button>
        }
        else
        {
            <div class="icon-button ghost"></div>
        }
    </header>

    @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
    {
        <section class="miniapp-banner error">
            @ViewModel.ErrorMessage
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ViewModel.StatusMessage))
    {
        <section class="miniapp-banner success">
            @ViewModel.StatusMessage
        </section>
    }

    <main class="miniapp-content">
        @if (ViewModel.IsLoading)
        {
            <section class="miniapp-panel">
                <div class="skeleton-title"></div>
                <div class="skeleton-line"></div>
                <div class="skeleton-card"></div>
                <div class="skeleton-card"></div>
            </section>
        }
        else
        {
            @switch (ActiveTab)
            {
                case MiniAppTab.Channels:
                    <section class="miniapp-stack">
                        <article class="miniapp-hero">
                            <div>
                                <span class="miniapp-kicker">Client workspace</span>
                                <h2>My Private Channels</h2>
                                <p>Channels that you explicitly shared with the bot and where it can already post messages.</p>
                            </div>
                            <div class="miniapp-user-chip">
                                <strong>@ViewModel.DisplayName</strong>
                                <span>@(ViewModel.IsAuthenticated
                                    ? (string.IsNullOrWhiteSpace(ViewModel.Username) ? "Verified Telegram session" : $"@{ViewModel.Username?.TrimStart('@')}")
                                    : "Authorization required")</span>
                            </div>
                        </article>

                        <article class="miniapp-panel">
                            <div class="channel-actions">
                                <button class="secondary-action" type="button" @onclick="RefreshAsync" disabled="@ViewModel.IsRefreshing">
                                    @(ViewModel.IsRefreshing ? "Refreshing..." : "Refresh list")
                                </button>
                                <button class="primary-action" type="button" @onclick="ShowAddChannelHintAsync">Add channels from bot chat</button>
                            </div>
                        </article>

                        @if (ViewModel.IsAuthenticated && ViewModel.Channels.Count == 0)
                        {
                            <article class="miniapp-panel empty-state">
                                <h3>No channels yet</h3>
                                <p>Add the bot as an admin in your private channel, then tap the channel picker in the bot chat and refresh this list.</p>
                                <button class="primary-action" type="button" @onclick="ShowAddChannelHintAsync">What to do</button>
                            </article>
                        }
                        else
                        {
                            <div class="channel-list">
                                @foreach (var channel in ViewModel.Channels)
                                {
                                    var isBusy = ViewModel.IsChannelBusy(channel.ChannelId);
                                    <article class="channel-card">
                                        <div class="channel-card-header">
                                            <div class="channel-avatar">@BuildAvatar(channel.ChannelName)</div>
                                            <div class="channel-meta">
                                                <div class="channel-name-row">
                                                    <h3>@channel.ChannelName</h3>
                                                    <span class="status-pill @GetStatusCssClass(channel)">
                                                        @GetStatusLabel(channel)
                                                    </span>
                                                </div>
                                                <p class="channel-reference">
                                                    @if (TryBuildReferenceHref(channel.ChannelReference, out var referenceHref))
                                                    {
                                                        <a href="@referenceHref" target="_blank" rel="noreferrer noopener">@FormatReference(channel.ChannelReference)</a>
                                                    }
                                                    else
                                                    {
                                                        @FormatReference(channel.ChannelReference)
                                                    }
                                                </p>
                                                <p class="channel-sync">Last verified: @FormatDate(channel.LastPostCollectedAtUtc)</p>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(channel.LastCollectorError))
                                        {
                                            <div class="channel-warning">@channel.LastCollectorError</div>
                                        }

                                        <div class="channel-actions">
                                            <button class="channel-action meta" type="button" @onclick="() => OpenSubscriptions(channel)" disabled="@isBusy">Subscriptions</button>
                                            <button class="channel-action icon start" type="button" title="Start" aria-label="Start" @onclick="() => StartAsync(channel.ChannelId)" disabled="@(channel.IsActive || isBusy)">
                                                <span class="action-icon">▶</span>
                                            </button>
                                            <button class="channel-action icon stop" type="button" title="Stop" aria-label="Stop" @onclick="() => StopAsync(channel.ChannelId)" disabled="@(!channel.IsActive || isBusy)">
                                                <span class="action-icon">⏸</span>
                                            </button>
                                            <button class="channel-action icon delete" type="button" title="Delete" aria-label="Delete" @onclick="() => DeleteAsync(channel.ChannelId)" disabled="@isBusy">
                                                <span class="action-icon">🗑</span>
                                            </button>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                    break;

                case MiniAppTab.Summary:
                    <section class="miniapp-stack">
                        <article class="miniapp-panel">
                            <div class="segmented-tabs">
                                <button class="segment active" type="button">Single Day</button>
                                <button class="segment" type="button" disabled>Date Range</button>
                            </div>
                        </article>

                        <article class="miniapp-panel placeholder-panel">
                            <h3>Summary is coming next</h3>
                            <p>This screen is reserved for daily and range summaries, duplicate groups, and highlights.</p>
                            <ul class="placeholder-list">
                                <li>Calendar filters</li>
                                <li>Media and edited-post toggles</li>
                                <li>Generate summary action</li>
                            </ul>
                        </article>
                    </section>
                    break;

                case MiniAppTab.Settings:
                    <section class="miniapp-stack">
                        <article class="miniapp-panel placeholder-panel">
                            <h3>Settings placeholder</h3>
                            <p>This section is ready for notification controls, language preferences, and future bot options.</p>
                            <button class="secondary-action" type="button" @onclick="ShowSettingsHintAsync">Preview planned options</button>
                        </article>
                    </section>
                    break;
            }
        }
    </main>

    <nav class="miniapp-bottom-nav" aria-label="Mini App sections">
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Channels ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Channels)">
            <span class="nav-icon">[]</span>
            <span>Channels</span>
        </button>
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Summary ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Summary)">
            <span class="nav-icon">==</span>
            <span>Summary</span>
        </button>
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Settings ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Settings)">
            <span class="nav-icon">::</span>
            <span>Settings</span>
        </button>
    </nav>

    @if (SelectedChannel is not null)
    {
        <div class="modal-backdrop" @onclick="CloseSubscriptions">
            <section class="subscription-modal" @onclick:stopPropagation="true">
                <div class="subscription-modal-header">
                    <div>
                        <span class="miniapp-kicker">Subscriptions</span>
                        <h3>@SelectedChannel.ChannelName</h3>
                        <p>Manage source channels for this destination channel.</p>
                    </div>
                    <button class="icon-button" type="button" @onclick="CloseSubscriptions" aria-label="Close subscriptions">
                        <span class="close-glyph">×</span>
                    </button>
                </div>

                @if (SelectedChannel.Subscriptions.Count == 0)
                {
                    <article class="miniapp-panel empty-state compact">
                        <h4>No source subscriptions yet</h4>
                        <p>Send a Telegram channel link into this connected channel to create one.</p>
                    </article>
                }
                else
                {
                    <div class="channel-list modal-subscription-list">
                        @foreach (var subscription in SelectedChannel.Subscriptions)
                        {
                            var subscriptionBusy = ViewModel.IsSubscriptionBusy(subscription.SubscriptionId);
                            <article class="channel-card nested-card">
                                <div class="channel-card-header">
                                    <div class="channel-avatar">@BuildAvatar(subscription.ChannelName)</div>
                                    <div class="channel-meta">
                                        <div class="channel-name-row">
                                            <h4>@subscription.ChannelName</h4>
                                            <span class="status-pill @GetSubscriptionStatusCssClass(subscription)">
                                                @GetSubscriptionStatusLabel(subscription)
                                            </span>
                                        </div>
                                        <p class="channel-reference">
                                            @if (TryBuildReferenceHref(subscription.ChannelReference, out var subscriptionReferenceHref))
                                            {
                                                <a href="@subscriptionReferenceHref" target="_blank" rel="noreferrer noopener">@FormatReference(subscription.ChannelReference)</a>
                                            }
                                            else
                                            {
                                                @FormatReference(subscription.ChannelReference)
                                            }
                                        </p>
                                        <p class="channel-sync">Last delivery: @FormatDate(subscription.LastDeliveredAtUtc)</p>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(subscription.LastCollectorError))
                                {
                                    <div class="channel-warning">@subscription.LastCollectorError</div>
                                }

                                <div class="channel-actions compact-actions">
                                    <button class="channel-action icon start" type="button" title="Start" aria-label="Start subscription" @onclick="() => StartSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@(subscription.IsActive || subscriptionBusy || !SelectedChannel.IsActive)">
                                        <span class="action-icon">▶</span>
                                    </button>
                                    <button class="channel-action icon stop" type="button" title="Stop" aria-label="Stop subscription" @onclick="() => StopSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@(!subscription.IsActive || subscriptionBusy)">
                                        <span class="action-icon">⏸</span>
                                    </button>
                                    <button class="channel-action icon delete" type="button" title="Delete" aria-label="Delete subscription" @onclick="() => DeleteSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@subscriptionBusy">
                                        <span class="action-icon">🗑</span>
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

@code {
    private MiniAppTab ActiveTab { get; set; } = MiniAppTab.Channels;
    private MiniAppChannelDto? SelectedChannel { get; set; }

    private string CurrentTitle => ActiveTab switch
    {
        MiniAppTab.Channels => "My Private Channels",
        MiniAppTab.Summary => "Summary",
        MiniAppTab.Settings => "Settings",
        _ => "Channels Monitor"
    };

    private string CurrentSubtitle => ActiveTab switch
    {
        MiniAppTab.Channels => "Manage channels where the bot has admin access.",
        MiniAppTab.Summary => "Summary tools are reserved here for the next iteration.",
        MiniAppTab.Settings => "Fine-tune the Mini App experience.",
        _ => string.Empty
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ViewModel.InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ActivateTab(MiniAppTab tab) => ActiveTab = tab;

    private async Task StartAsync(Guid channelId) => await ExecuteAsync(() => ViewModel.StartChannelAsync(channelId));

    private async Task StopAsync(Guid channelId) => await ExecuteAsync(() => ViewModel.StopChannelAsync(channelId));

    private async Task DeleteAsync(Guid channelId) => await ExecuteAsync(() => ViewModel.DeleteChannelAsync(channelId));

    private async Task StartSubscriptionAsync(Guid channelId, Guid subscriptionId) => await ExecuteAsync(() => ViewModel.StartSubscriptionAsync(channelId, subscriptionId));

    private async Task StopSubscriptionAsync(Guid channelId, Guid subscriptionId) => await ExecuteAsync(() => ViewModel.StopSubscriptionAsync(channelId, subscriptionId));

    private async Task DeleteSubscriptionAsync(Guid channelId, Guid subscriptionId) => await ExecuteAsync(() => ViewModel.DeleteSubscriptionAsync(channelId, subscriptionId));

    private void OpenSubscriptions(MiniAppChannelDto channel) => SelectedChannel = channel;

    private void CloseSubscriptions() => SelectedChannel = null;

    private Task OpenDrawerAsync() =>
        ViewModel.ShowPlaceholderAsync("Mini App navigation drawer is reserved for future sections.").AsTask();

    private Task ShowAddChannelHintAsync() =>
        ViewModel.ShowPlaceholderAsync("Make the bot an admin in your private channel first, then use the Add my channel button in the bot chat. It will appear here after refresh.").AsTask();

    private static string GetStatusLabel(MiniAppChannelDto channel) =>
        channel.IsActive ? "Active" : "Stopped";

    private static string GetStatusCssClass(MiniAppChannelDto channel) =>
        channel.IsActive ? "active" : "paused";

    private static string GetSubscriptionStatusLabel(MiniAppSourceSubscriptionDto subscription) =>
        subscription.IsActive ? "Active" : "Stopped";

    private static string GetSubscriptionStatusCssClass(MiniAppSourceSubscriptionDto subscription) =>
        subscription.IsActive ? "active" : "paused";

    private Task ShowSettingsHintAsync() =>
        ViewModel.ShowPlaceholderAsync("Settings will be connected in the next iteration.").AsTask();

    private async Task RefreshAsync() => await ExecuteAsync(() => RefreshViewModelAsync());

    private async Task ExecuteAsync(Func<Task<bool>> action)
    {
        await action();
        if (SelectedChannel is not null)
        {
            SelectedChannel = ViewModel.Channels.FirstOrDefault(x => x.ChannelId == SelectedChannel.ChannelId);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> RefreshViewModelAsync()
    {
        await ViewModel.RefreshChannelsAsync();
        return true;
    }

    private static string BuildAvatar(string channelName)
    {
        var letters = new string(channelName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(part => part.Length > 0)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray());

        return string.IsNullOrWhiteSpace(letters)
            ? "CH"
            : letters;
    }

    private static string FormatReference(string channelReference)
    {
        if (string.IsNullOrWhiteSpace(channelReference))
        {
            return "Private channel";
        }

        if (channelReference.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            return channelReference;
        }

        return channelReference.StartsWith("@", StringComparison.Ordinal) ? channelReference : $"@{channelReference}";
    }

    private static bool TryBuildReferenceHref(string channelReference, out string href)
    {
        href = string.Empty;

        if (string.IsNullOrWhiteSpace(channelReference))
        {
            return false;
        }

        if (Uri.TryCreate(channelReference, UriKind.Absolute, out var uri))
        {
            href = uri.ToString();
            return true;
        }

        var reference = channelReference.Trim().TrimStart('@');
        if (string.IsNullOrWhiteSpace(reference))
        {
            return false;
        }

        href = $"https://t.me/{reference}";
        return true;
    }

    private static string FormatDate(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("dd MMM yyyy, HH:mm") ?? "Waiting for first sync";

    private enum MiniAppTab
    {
        Channels,
        Summary,
        Settings
    }
}
