@page "/mini-app"
@layout Layout.MiniAppLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject ViewModels.MiniAppViewModel ViewModel

<PageTitle>Channels Monitor Mini App</PageTitle>

<div class="miniapp-screen" @ontouchstart="HandleTouchStart" @ontouchend="HandleTouchEnd">
    <header class="miniapp-topbar">
        <button class="icon-button" type="button" @onclick="OpenDrawerAsync" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="miniapp-title-wrap">
            <h1>@CurrentTitle</h1>
            <p>@CurrentSubtitle</p>
        </div>

        @if (ActiveTab == MiniAppTab.Channels)
        {
            <button class="icon-button accent" type="button" @onclick="ShowAddChannelHintAsync" aria-label="Add channel">+</button>
        }
        else
        {
            <div class="icon-button ghost"></div>
        }
    </header>

    @if (!string.IsNullOrWhiteSpace(ViewModel.ErrorMessage))
    {
        <section class="miniapp-banner error">
            @ViewModel.ErrorMessage
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(ViewModel.StatusMessage))
    {
        <section class="miniapp-banner success">
            @ViewModel.StatusMessage
        </section>
    }

    <main class="miniapp-content">
        @if (ViewModel.IsLoading)
        {
            <section class="miniapp-panel">
                <div class="skeleton-title"></div>
                <div class="skeleton-line"></div>
                <div class="skeleton-card"></div>
                <div class="skeleton-card"></div>
            </section>
        }
        else
        {
            <section class="miniapp-tab-stage @TabTransitionClass">
                @switch (ActiveTab)
                {
                    case MiniAppTab.Channels:
                        <section class="miniapp-stack">
                            <article class="miniapp-copy-block">
                                <p>Manage your private channels and their status</p>
                                <div class="miniapp-copy-actions">
                                    <button class="secondary-action slim" type="button" @onclick="RefreshAsync" disabled="@ViewModel.IsRefreshing">
                                        @(ViewModel.IsRefreshing ? "Refreshing..." : "Refresh list")
                                    </button>
                                    <button class="secondary-action slim" type="button" @onclick="ShowAddChannelHintAsync">How to add</button>
                                </div>
                            </article>

                            @if (ViewModel.IsAuthenticated && ViewModel.Channels.Count == 0)
                            {
                                <article class="miniapp-panel empty-state">
                                    <h3>No channels yet</h3>
                                    <p>Add the bot as an admin in your private channel, then tap the channel picker in the bot chat and refresh this list.</p>
                                    <button class="primary-action" type="button" @onclick="ShowAddChannelHintAsync">What to do</button>
                                </article>
                            }
                            else
                            {
                                <div class="channel-list">
                                    @foreach (var channel in ViewModel.Channels)
                                    {
                                        var isBusy = ViewModel.IsChannelBusy(channel.ChannelId);
                                        <article class="channel-card">
                                            <div class="channel-card-header">
                                                <div class="channel-avatar">
                                                    @if (!string.IsNullOrWhiteSpace(channel.AvatarImageUrl))
                                                    {
                                                        <img src="@channel.AvatarImageUrl" alt="@channel.ChannelName logo" loading="lazy" />
                                                    }
                                                    else
                                                    {
                                                        <span>@BuildAvatar(channel.ChannelName)</span>
                                                    }
                                                </div>
                                                <div class="channel-meta">
                                                    <div class="channel-name-row">
                                                        <h3>@channel.ChannelName</h3>
                                                        <span class="status-pill @GetStatusCssClass(channel)">
                                                            @GetStatusLabel(channel)
                                                        </span>
                                                    </div>
                                                    <p class="channel-reference">
                                                        @if (TryBuildReferenceHref(channel.ChannelReference, out var channelReferenceHref))
                                                        {
                                                            <a href="@channelReferenceHref" target="_blank" rel="noreferrer noopener">@FormatReference(channel.ChannelReference)</a>
                                                        }
                                                        else
                                                        {
                                                            @FormatReference(channel.ChannelReference)
                                                        }
                                                    </p>
                                                    <p class="channel-sync">Last sync: @FormatDate(channel.LastPostCollectedAtUtc)</p>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(channel.LastCollectorError))
                                            {
                                                <div class="channel-warning">@channel.LastCollectorError</div>
                                            }

                                            <div class="channel-tools">
                                                <button class="channel-tool" type="button" @onclick="() => OpenSubscriptions(channel)" disabled="@isBusy">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                                        <path d="M5 5h6v6H5zM13 5h6v6h-6zM5 13h6v6H5zM13 13h6v6h-6z" fill="currentColor" />
                                                    </svg>
                                                    <span>Subscriptions</span>
                                                </button>
                                            </div>

                                            <div class="channel-actions">
                                                <button class="channel-action start" type="button" title="Start" aria-label="Start" @onclick="() => StartAsync(channel.ChannelId)" disabled="@(channel.IsActive || isBusy)">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                                        <path d="M8 6v12l10-6z" fill="currentColor" />
                                                    </svg>
                                                    <span>Start</span>
                                                </button>
                                                <button class="channel-action stop" type="button" title="Stop" aria-label="Stop" @onclick="() => StopAsync(channel.ChannelId)" disabled="@(!channel.IsActive || isBusy)">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                                        <path d="M7 6h4v12H7zm6 0h4v12h-4z" fill="currentColor" />
                                                    </svg>
                                                    <span>Stop</span>
                                                </button>
                                                <button class="channel-action delete" type="button" title="Delete" aria-label="Delete" @onclick="() => DeleteAsync(channel.ChannelId)" disabled="@isBusy">
                                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                                        <path d="M9 3h6l1 2h4v2H4V5h4zm1 6h2v8h-2zm4 0h2v8h-2zM7 9h2v8H7zm1 11h8a2 2 0 0 0 2-2V8H6v10a2 2 0 0 0 2 2z" fill="currentColor" />
                                                    </svg>
                                                    <span>Delete</span>
                                                </button>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>
                        break;

                    case MiniAppTab.Summary:
                        <section class="miniapp-stack">
                            <article class="miniapp-panel">
                                <div class="segmented-tabs">
                                    <button class="segment active" type="button">Single Day</button>
                                    <button class="segment" type="button" disabled>Date Range</button>
                                </div>
                            </article>

                            <article class="miniapp-panel form-panel">
                                <label class="panel-label">Select Date</label>
                                <button class="select-button" type="button" disabled>
                                    <span>26 Apr 2026</span>
                                    <span class="select-arrow">v</span>
                                </button>
                            </article>

                            <article class="miniapp-panel form-panel">
                                <label class="panel-label">Filters</label>
                                <div class="summary-checklist">
                                    <label><input type="checkbox" checked disabled /> Include media</label>
                                    <label><input type="checkbox" checked disabled /> Include edited posts</label>
                                    <label><input type="checkbox" checked disabled /> Group duplicates</label>
                                </div>
                            </article>

                            <article class="miniapp-panel action-panel">
                                <button class="primary-action wide" type="button" disabled>Generate Summary</button>
                            </article>

                            <article class="miniapp-panel placeholder-panel">
                                <div class="summary-block-title">
                                    <h3>Last Summary</h3>
                                    <button class="secondary-action slim" type="button" disabled>View Summary</button>
                                </div>
                                <div class="summary-metrics">
                                    <p>25 Apr 2026</p>
                                    <p>Channels analyzed: 5</p>
                                    <p>Posts: 124</p>
                                </div>
                            </article>

                            <article class="miniapp-panel placeholder-panel">
                                <h3>Summary Preview</h3>
                                <div class="summary-preview-grid">
                                    <div>
                                        <h4>Top topics</h4>
                                        <ul class="placeholder-list">
                                            <li>War updates</li>
                                            <li>Politics</li>
                                            <li>Economy</li>
                                            <li>Other</li>
                                        </ul>
                                    </div>
                                    <div>
                                        <h4>Highlights</h4>
                                        <ol class="placeholder-list ordered">
                                            <li>Significant escalation in the east.</li>
                                            <li>New economic measures announced.</li>
                                            <li>International reactions and statements.</li>
                                        </ol>
                                    </div>
                                </div>
                                <button class="secondary-action wide" type="button" disabled>View Full Summary</button>
                            </article>
                        </section>
                        break;

                    case MiniAppTab.Settings:
                        <section class="miniapp-stack">
                            <article class="miniapp-panel placeholder-panel">
                                <h3>Settings placeholder</h3>
                                <p>This section is ready for notification controls, language preferences, and future bot options.</p>
                                <button class="secondary-action" type="button" @onclick="ShowSettingsHintAsync">Preview planned options</button>
                            </article>
                        </section>
                        break;

                }
            </section>
        }
    </main>

    <nav class="miniapp-bottom-nav" aria-label="Mini App sections">
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Channels ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Channels)">
            <span class="nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="7" rx="2" fill="currentColor" />
                    <rect x="3" y="13" width="8" height="8" rx="2" fill="currentColor" opacity="0.88" />
                    <rect x="13" y="13" width="8" height="8" rx="2" fill="currentColor" opacity="0.72" />
                </svg>
            </span>
            <span>Channels</span>
        </button>
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Summary ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Summary)">
            <span class="nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <path d="M12 3a9 9 0 1 0 9 9h-7a2 2 0 0 1-2-2z" fill="currentColor" />
                    <path d="M14 3.5v7.5h7.5A7.5 7.5 0 0 0 14 3.5z" fill="currentColor" opacity="0.74" />
                </svg>
            </span>
            <span>Summary</span>
        </button>
        <button class="bottom-nav-item @(ActiveTab == MiniAppTab.Settings ? "selected" : null)" type="button" @onclick="() => ActivateTab(MiniAppTab.Settings)">
            <span class="nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                    <path d="M10.6 2h2.8l.6 2.4a7.8 7.8 0 0 1 1.8.8l2.1-1.2 2 2-1.2 2.1c.34.57.61 1.18.8 1.82L22 10.6v2.8l-2.4.6a7.8 7.8 0 0 1-.8 1.8l1.2 2.1-2 2-2.1-1.2a7.8 7.8 0 0 1-1.82.8L13.4 22h-2.8l-.6-2.4a7.8 7.8 0 0 1-1.8-.8L6.1 20l-2-2 1.2-2.1a7.8 7.8 0 0 1-.8-1.82L2 13.4v-2.8l2.4-.6c.19-.64.46-1.25.8-1.8L4 6.1l2-2 2.1 1.2c.57-.34 1.18-.61 1.82-.8zM12 8.2A3.8 3.8 0 1 0 12 15.8 3.8 3.8 0 0 0 12 8.2z" fill="currentColor" />
                </svg>
            </span>
            <span>Settings</span>
        </button>
    </nav>

    @if (SelectedChannel is not null)
    {
        <div class="modal-backdrop" @onclick="CloseSubscriptions">
            <section class="subscription-modal" @onclick:stopPropagation="true">
                <div class="subscription-modal-header">
                    <div>
                        <span class="miniapp-kicker">Subscriptions</span>
                        <h3>@SelectedChannel.ChannelName</h3>
                        <p>Manage source channels for this destination channel.</p>
                    </div>
                    <button class="icon-button" type="button" @onclick="CloseSubscriptions" aria-label="Close subscriptions">
                        <span class="close-glyph">x</span>
                    </button>
                </div>

                @if (SelectedChannel.Subscriptions.Count == 0)
                {
                    <article class="miniapp-panel empty-state compact">
                        <h4>No source subscriptions yet</h4>
                        <p>Send a Telegram channel link into this connected channel to create one.</p>
                    </article>
                }
                else
                {
                    <div class="channel-list modal-subscription-list">
                        @foreach (var subscription in SelectedChannel.Subscriptions)
                        {
                            var subscriptionBusy = ViewModel.IsSubscriptionBusy(subscription.SubscriptionId);
                            <article class="channel-card nested-card">
                                <div class="channel-card-header">
                                    <div class="channel-avatar">
                                        @if (!string.IsNullOrWhiteSpace(subscription.AvatarImageUrl))
                                        {
                                            <img src="@subscription.AvatarImageUrl" alt="@subscription.ChannelName logo" loading="lazy" />
                                        }
                                        else
                                        {
                                            <span>@BuildAvatar(subscription.ChannelName)</span>
                                        }
                                    </div>
                                    <div class="channel-meta">
                                        <div class="channel-name-row">
                                            <h4>@subscription.ChannelName</h4>
                                            <span class="status-pill @GetSubscriptionStatusCssClass(subscription)">
                                                @GetSubscriptionStatusLabel(subscription)
                                            </span>
                                        </div>
                                        <p class="channel-reference">
                                            @if (TryBuildReferenceHref(subscription.ChannelReference, out var subscriptionReferenceHref))
                                            {
                                                <a href="@subscriptionReferenceHref" target="_blank" rel="noreferrer noopener">@FormatReference(subscription.ChannelReference)</a>
                                            }
                                            else
                                            {
                                                @FormatReference(subscription.ChannelReference)
                                            }
                                        </p>
                                        <p class="channel-sync">Last delivery: @FormatDate(subscription.LastDeliveredAtUtc)</p>
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(subscription.LastCollectorError))
                                {
                                    <div class="channel-warning">@subscription.LastCollectorError</div>
                                }

                                <div class="channel-actions compact-actions">
                                    <button class="channel-action start" type="button" title="Start" aria-label="Start subscription" @onclick="() => StartSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@(subscription.IsActive || subscriptionBusy || !SelectedChannel.IsActive)">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M8 6v12l10-6z" fill="currentColor" />
                                        </svg>
                                        <span>Start</span>
                                    </button>
                                    <button class="channel-action stop" type="button" title="Stop" aria-label="Stop subscription" @onclick="() => StopSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@(!subscription.IsActive || subscriptionBusy)">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M7 6h4v12H7zm6 0h4v12h-4z" fill="currentColor" />
                                        </svg>
                                        <span>Stop</span>
                                    </button>
                                    <button class="channel-action delete" type="button" title="Delete" aria-label="Delete subscription" @onclick="() => DeleteSubscriptionAsync(SelectedChannel.ChannelId, subscription.SubscriptionId)" disabled="@subscriptionBusy">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M9 3h6l1 2h4v2H4V5h4zm1 6h2v8h-2zm4 0h2v8h-2zM7 9h2v8H7zm1 11h8a2 2 0 0 0 2-2V8H6v10a2 2 0 0 0 2 2z" fill="currentColor" />
                                        </svg>
                                        <span>Delete</span>
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

@code {
    private MiniAppTab ActiveTab { get; set; } = MiniAppTab.Channels;
    private MiniAppChannelDto? SelectedChannel { get; set; }
    private string TabTransitionClass { get; set; } = "tab-enter";
    private double? TouchStartX { get; set; }

    private string CurrentTitle => ActiveTab switch
    {
        MiniAppTab.Channels => "My Private Channels",
        MiniAppTab.Summary => "Summary",
        MiniAppTab.Settings => "Settings",
        _ => "Channels Monitor"
    };

    private string CurrentSubtitle => ActiveTab switch
    {
        MiniAppTab.Channels => "Channels where the bot is already an admin.",
        MiniAppTab.Summary => "Daily overview and highlights.",
        MiniAppTab.Settings => "Future notification and preference controls.",
        _ => string.Empty
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ViewModel.InitializeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void ActivateTab(MiniAppTab tab)
    {
        if (tab == ActiveTab)
        {
            return;
        }

        var direction = GetTabIndex(tab) > GetTabIndex(ActiveTab) ? "tab-enter-left" : "tab-enter-right";
        ActiveTab = tab;
        _ = AnimateTabTransitionAsync(direction);
    }

    private async Task StartAsync(Guid channelId) => await ExecuteAsync(() => ViewModel.StartChannelAsync(channelId));

    private async Task StopAsync(Guid channelId) => await ExecuteAsync(() => ViewModel.StopChannelAsync(channelId));

    private async Task StartSubscriptionAsync(Guid channelId, Guid subscriptionId) => await ExecuteAsync(() => ViewModel.StartSubscriptionAsync(channelId, subscriptionId));

    private async Task StopSubscriptionAsync(Guid channelId, Guid subscriptionId) => await ExecuteAsync(() => ViewModel.StopSubscriptionAsync(channelId, subscriptionId));

    private void OpenSubscriptions(MiniAppChannelDto channel) => SelectedChannel = channel;

    private void CloseSubscriptions() => SelectedChannel = null;

    private Task OpenDrawerAsync() =>
        ViewModel.ShowPlaceholderAsync("Mini App navigation drawer is reserved for future sections.").AsTask();

    private Task ShowAddChannelHintAsync() =>
        ViewModel.ShowPlaceholderAsync("Make the bot an admin in your private channel first, then use the Add my channel button in the bot chat. It will appear here after refresh.").AsTask();

    private static string GetStatusLabel(MiniAppChannelDto channel) =>
        channel.IsActive ? "Active" : "Stopped";

    private static string GetStatusCssClass(MiniAppChannelDto channel) =>
        channel.IsActive ? "active" : "paused";

    private static string GetSubscriptionStatusLabel(MiniAppSourceSubscriptionDto subscription) =>
        subscription.IsActive ? "Active" : "Stopped";

    private static string GetSubscriptionStatusCssClass(MiniAppSourceSubscriptionDto subscription) =>
        subscription.IsActive ? "active" : "paused";

    private Task ShowSettingsHintAsync() =>
        ViewModel.ShowPlaceholderAsync("Settings will be connected in the next iteration.").AsTask();

    private async Task RefreshAsync() => await ExecuteAsync(RefreshViewModelAsync);

    private async Task ExecuteAsync(Func<Task<bool>> action)
    {
        await action();
        if (SelectedChannel is not null)
        {
            SelectedChannel = ViewModel.Channels.FirstOrDefault(x => x.ChannelId == SelectedChannel.ChannelId);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> RefreshViewModelAsync()
    {
        await ViewModel.RefreshChannelsAsync();
        return true;
    }

    private async Task DeleteAsync(Guid channelId)
    {
        var confirmed = await ViewModel.ConfirmAsync("Delete this connected channel?");
        if (!confirmed)
        {
            return;
        }

        await ExecuteAsync(() => ViewModel.DeleteChannelAsync(channelId));
    }

    private async Task DeleteSubscriptionAsync(Guid channelId, Guid subscriptionId)
    {
        var confirmed = await ViewModel.ConfirmAsync("Delete this subscription?");
        if (!confirmed)
        {
            return;
        }

        await ExecuteAsync(() => ViewModel.DeleteSubscriptionAsync(channelId, subscriptionId));
    }

    private void HandleTouchStart(TouchEventArgs args)
    {
        var touch = args.Touches.FirstOrDefault();
        TouchStartX = touch?.ClientX;
    }

    private void HandleTouchEnd(TouchEventArgs args)
    {
        if (TouchStartX is null)
        {
            return;
        }

        var touch = args.ChangedTouches.FirstOrDefault();
        if (touch is null)
        {
            TouchStartX = null;
            return;
        }

        var endX = touch.ClientX;
        var deltaX = endX - TouchStartX.Value;
        TouchStartX = null;

        const double threshold = 56;
        if (Math.Abs(deltaX) < threshold)
        {
            return;
        }

        var currentIndex = GetTabIndex(ActiveTab);
        var tabCount = Enum.GetValues<MiniAppTab>().Length;
        var targetIndex = deltaX < 0
            ? (currentIndex + 1) % tabCount
            : (currentIndex - 1 + tabCount) % tabCount;

        if (targetIndex == currentIndex)
        {
            return;
        }

        ActivateTab((MiniAppTab)targetIndex);
    }

    private async Task AnimateTabTransitionAsync(string cssClass)
    {
        TabTransitionClass = cssClass;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(280);
        TabTransitionClass = "tab-enter";
        await InvokeAsync(StateHasChanged);
    }

    private static int GetTabIndex(MiniAppTab tab) => tab switch
    {
        MiniAppTab.Channels => 0,
        MiniAppTab.Summary => 1,
        MiniAppTab.Settings => 2,
        _ => 0
    };

    private static string BuildAvatar(string channelName)
    {
        var letters = new string(channelName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(part => part.Length > 0)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray());

        return string.IsNullOrWhiteSpace(letters)
            ? "CH"
            : letters;
    }

    private static string FormatReference(string channelReference)
    {
        if (string.IsNullOrWhiteSpace(channelReference))
        {
            return "Private channel";
        }

        if (channelReference.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            return channelReference;
        }

        return channelReference.StartsWith("@", StringComparison.Ordinal) ? channelReference : $"@{channelReference}";
    }

    private static bool TryBuildReferenceHref(string channelReference, out string href)
    {
        href = string.Empty;

        if (string.IsNullOrWhiteSpace(channelReference))
        {
            return false;
        }

        if (Uri.TryCreate(channelReference, UriKind.Absolute, out var uri))
        {
            href = uri.ToString();
            return true;
        }

        var reference = channelReference.Trim().TrimStart('@');
        if (string.IsNullOrWhiteSpace(reference))
        {
            return false;
        }

        href = $"https://t.me/{reference}";
        return true;
    }

    private static string FormatDate(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("dd MMM yyyy, HH:mm") ?? "Waiting for first sync";

    private enum MiniAppTab
    {
        Channels,
        Summary,
        Settings
    }
}
